{% extends 'layout.html.twig' %}
{% import 'macros/macros.html.twig' as macros %}
{% block title %}Quarantined render requests{% endblock %}
{% block headline %}Quarantined render requests{% endblock %}
{% block body %}

    {% frame %}
        <div class="card">
            <div class="card-header">
                <div class="card-header-bar">
                    <div class="card-header-title">
                        <h3>Quarantined render requests</h3>
                    </div>
                </div>
            </div>
            <div class="datatable">
                <table class="datatable-table">
                    <thead>
                    <tr>
                        <th scope="col">Domain</th>
                        <th scope="col">Repository URL</th>
                        <th scope="col" data-type="actions">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for quarantinedRequest in pagination.getItems() %}
                        <tr data-id="{{ quarantinedRequest.id }}">
                            <td>{{ quarantinedRequest.domain }}</td>
                            <td>{{ quarantinedRequest.pushEvent.repositoryUrl }}</td>
                            <td data-type="actions" data-label="Actions">
                                <a class="datatable-action" title="Allow" href="{{ path('admin_docs_quarantine_allow', {'quarantinedDocumentation': quarantinedRequest.id}) }}">
                                    <span class="datatable-action-icon">{{ icon('actions-check') }}</span>
                                    <span class="datatable-action-label datatable-visually-hidden">Allow</span>
                                </a>
                                <a class="datatable-action" title="Disllow" href="{{ path('admin_docs_quarantine_disallow', {'quarantinedDocumentation': quarantinedRequest.id}) }}">
                                    <span class="datatable-action-icon">{{ icon('actions-ban') }}</span>
                                    <span class="datatable-action-label datatable-visually-hidden">Disallow</span>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5">
                                <div class="alert alert-warning">No documentation requests quarantined.</div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            {% if pagination.getTotalItemCount() > 10 %}
                <div class="card-footer">
                    {{ knp_pagination_render(pagination) }}
                </div>
            {% endif %}
        </div>
    {% endframe %}

{% endblock %}
